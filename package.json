{
  "name": "tailwind-2-starter",
  "version": "1.0.0",
  "description": "Starter package with Tailwind CSS",
  "author": {
    "name": "Serey Mochalov",
    "email": "mail@newwebmaster.ru",
    "url": "https://newwebmaster.com"
  },
  "devDependencies": {
    "concurrently": "^5.3.0",
    "live-server": "^1.2.1"
  },
  "scripts": {
    "dev": "concurrently \"tailwindcss -i src/css/main.css -o public/css/style.css --watch\" \"live-server ./public\"",
    "build": "tailwindcss -i src/css/main.css -o public/css/style.css --minify"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "tailwindcss": "^4.2.1"
  }
}
